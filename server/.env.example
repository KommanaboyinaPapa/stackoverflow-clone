# Server
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/stackoverflow-clone
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
NODE_ENV=development

# Email (Nodemailer) — French OTP, device login OTP, forgot password, invoices
# Use either SMTP_* or EMAIL_USER / EMAIL_PASS (Gmail app password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# Razorpay TEST MODE (Dashboard → Test Mode → API Keys: rzp_test_...)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Client (optional): REACT_APP_RAZORPAY_KEY_ID same as RAZORPAY_KEY_ID

# Dev only — bypass time windows (never use in production)
PAYMENT_WINDOW_OVERRIDE=false
MOBILE_LOGIN_OVERRIDE=true

# SMS providers (optional — demo OTP in dev when missing)
# Twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# MSG91
# MSG91_AUTH_KEY=
# MSG91_SENDER_ID=
# MSG91_TEMPLATE_ID=
